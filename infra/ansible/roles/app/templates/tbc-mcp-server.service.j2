[Unit]
Description=TBC MCP Server — FastAPI + MCP SDK, read-only Ask Anything endpoint
After=network.target postgresql.service ollama.service
Wants=postgresql.service

[Service]
Type=simple
User=tbc
Group=tbc
WorkingDirectory=/opt/tbc
EnvironmentFile=/etc/tbc/env
ExecStart=uv run python -m services.mcp_server.main
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tbc-mcp-server

[Install]
WantedBy=multi-user.target
