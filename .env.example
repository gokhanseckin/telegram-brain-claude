# Database
TBC_DATABASE_URL=postgresql+psycopg://tbc:tbc@localhost:5432/tbc

# Ollama (local models)
TBC_OLLAMA_BASE_URL=http://localhost:11434
TBC_UNDERSTANDING_MODEL=qwen2.5:7b-instruct-q4_K_M
TBC_EMBEDDING_MODEL=bge-m3

# Anthropic (tg-bot agent always uses this; brief/weekly when TBC_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
TBC_BRIEF_MODEL=claude-sonnet-4-6

# DeepSeek (Brief + Weekly — alternative to Anthropic)
DEEPSEEK_API_KEY=

# novita.ai (brief/weekly/agent when TBC_LLM_PROVIDER=novita)
NOVITA_API_KEY=
TBC_NOVITA_MODEL=google/gemma-3-27b-it

# Valid values: anthropic, deepseek, novita
TBC_LLM_PROVIDER=deepseek

# Telegram userbot (Telethon)
TBC_TG_API_ID=
TBC_TG_API_HASH=
TBC_TG_SESSION_PATH=/var/lib/tbc/session

# Telegram bot (aiogram) — for delivering Briefs and serving commands
TBC_TG_BOT_TOKEN=
TBC_TG_OWNER_USER_ID=

# Brief scheduling
TBC_BRIEF_TZ=Europe/Istanbul
TBC_BRIEF_TIME=07:00
TBC_WEEKLY_DAY=Monday
TBC_WEEKLY_TIME=08:00

# MCP server
TBC_MCP_BEARER_TOKEN=
TBC_MCP_PUBLIC_URL=https://mcp.example.com

# Logging
TBC_LOG_LEVEL=INFO
